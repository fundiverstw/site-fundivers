# Copy to .env and fill in. The anon key is safe to expose (RLS-protected, read-only public data).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Existing booking app that "Book now" / "Log in" CTAs link to.
VITE_APP_URL=https://app.fundiverstw.com

# Cloudflare deploy creds (same account as app-fundivers). Used by `npm run deploy`.
# Not VITE_-prefixed, so they stay server-side and never reach the browser bundle.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
