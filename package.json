{
  "name": "site-fundivers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FunDivers TW public marketing site — fast static SPA on Cloudflare, reading the shared Supabase catalog.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:e2e": "playwright install chromium && playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "verify": "npm run check && npm run lint && npm run format:check && npm run test",
    "deploy": "npm run verify && npm run build && dotenv -e .env -- wrangler deploy"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^26.1.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "date-fns": "^4.4.0"
  }
}
