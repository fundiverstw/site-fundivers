{
  "name": "site-fundivers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "FunDivers TW public marketing site — fast static SPA on Cloudflare, reading the shared Supabase catalog.",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "deploy": "npm run build && dotenv -e .env -- wrangler deploy"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^26.1.1",
    "dotenv-cli": "^8.0.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.7.3",
    "vite": "^7.0.0",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "date-fns": "^4.4.0"
  }
}
